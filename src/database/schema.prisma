// model:
// - users
// - guilds
// - artifacts
// - collaborations
// - discussions
// - collections
// - amplifies
// - media
// - notifications
// - watchlists
// - tags
// - engagement_artifact
// - engagement_discussion
// - guild_subscriptions
// - artifact_tags
// - verification_otps

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ==========================================
// MODULE: AUTH & USER
// ==========================================

model User {
  id            String     @id @default(ulid()) @db.Char(26)
  username      String     @unique @db.VarChar(255)
  email         String     @unique @db.VarChar(255)
  password      String?    @db.VarChar(255) // Nullable for Google OAuth
  auth_type     AuthType   @default(CREDENTIAL)
  is_verified   Boolean    @default(false)
  name          String     @db.VarChar(255)
  job_title     String?    @db.VarChar(255)
  job_status    JobStatus? @default(NONE)
  bio           String?    @db.Text
  github        String?    @db.VarChar(255)
  linkedin      String?    @db.VarChar(255)
  photo_profile String?    @db.VarChar(255)

  // counter
  count_artifacts  Int @default(0)
  count_watcher    Int @default(0)
  count_watchlist  Int @default(0)
  count_amplify    Int @default(0)
  count_collection Int @default(0)
  count_discussion Int @default(0)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  // Relations - Auth
  verification_otps VerificationOtp[]

  // Relations - Content & Guild
  owned_guilds       Guild[]             @relation("GuildOwner")
  guild_subs         GuildSubscription[]
  authored_artifacts Artifact[]          @relation("ArtifactAuthor")
  collaborations     Collaboration[]

  // Relations - Interaction
  discussions     Discussion[]
  collections     Collection[]
  amplifies       Amplify[]
  eng_artifacts   EngagementArtifact[]
  eng_discussions EngagementDiscussion[]

  // Relations - Social Network
  watching Watchlist[] @relation("WatcherRelations")
  watchers Watchlist[] @relation("WatchedRelations")

  // Relations - Notifications
  notifications    Notification[] @relation("ReceivedNotifications")
  triggered_notifs Notification[] @relation("TriggeredNotifications")

  @@index([username], map: "idx_user_username")
}

model VerificationOtp {
  id         String   @id @default(ulid()) @db.Char(26)
  user_id    String   @db.Char(26)
  otp_code   String   @db.VarChar(10)
  is_used    Boolean  @default(false)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_otp_user_id")
}

model Watchlist {
  id         String @id @default(ulid()) @db.Char(26)
  watcher_id String @db.Char(26) // Yang memantau
  watched_id String @db.Char(26) // Yang dipantau

  created_at DateTime @default(now()) @db.Timestamp(6)

  watcher User @relation("WatcherRelations", fields: [watcher_id], references: [id], onDelete: Cascade)
  watched User @relation("WatchedRelations", fields: [watched_id], references: [id], onDelete: Cascade)

  @@unique([watcher_id, watched_id])
  @@index([watcher_id], map: "idx_watchlist_watcher")
  @@index([watched_id], map: "idx_watchlist_watched")
}

// ==========================================
// MODULE: GUILD
// ==========================================

model Guild {
  id          String  @id @default(ulid()) @db.Char(26)
  slug        String  @unique @db.VarChar(255)
  owner_id    String  @db.Char(26)
  name        String  @db.VarChar(255)
  description String? @db.Text
  cover_image String? @db.VarChar(255)
  icon        String? @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  owner       User                @relation("GuildOwner", fields: [owner_id], references: [id])
  subscribers GuildSubscription[]
  artifacts   Artifact[]

  @@index([owner_id], map: "idx_guild_owner_id")
}

model GuildSubscription {
  id         String   @id @default(ulid()) @db.Char(26)
  user_id    String   @db.Char(26)
  guild_id   String   @db.Char(26)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@unique([user_id, guild_id])
  @@index([guild_id], map: "idx_guild_sub_guild_id")
}

// ==========================================
// MODULE: ARTIFACT & COLLABORATION
// ==========================================

model Artifact {
  id        String  @id @default(ulid()) @db.Char(26)
  slug      String  @unique @db.VarChar(255)
  author_id String  @db.Char(26)
  guild_id  String? @db.Char(26) // Nullable (Bisa diluar guild)

  title       String  @db.VarChar(255)
  content     String  @db.Text
  is_archived Boolean @default(false)

  // Denormalized Counters
  count_boosts    Int @default(0)
  count_reduces   Int @default(0)
  count_comments  Int @default(0)
  count_amplifies Int @default(0)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  author User   @relation("ArtifactAuthor", fields: [author_id], references: [id])
  guild  Guild? @relation(fields: [guild_id], references: [id], onDelete: SetNull)

  collaborations Collaboration[]
  media          Media[]
  discussions    Discussion[]
  collections    Collection[]
  amplifies      Amplify[]
  tags           ArtifactTag[]
  engagements    EngagementArtifact[]
  notifications  Notification[]

  @@index([author_id], map: "idx_artifact_author_id")
  @@index([guild_id], map: "idx_artifact_guild_id")
}

model Collaboration {
  id          String           @id @default(ulid()) @db.Char(26)
  user_id     String           @db.Char(26)
  artifact_id String           @db.Char(26)
  status      CollabStatusType @default(PENDING)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)

  @@unique([user_id, artifact_id])
  @@index([artifact_id], map: "idx_collab_artifact_id")
}

model Tag {
  id   String @id @default(ulid()) @db.Char(26)
  name String @unique @db.VarChar(100)

  artifacts ArtifactTag[]
}

model ArtifactTag {
  artifact_id String @db.Char(26)
  tag_id      String @db.Char(26)

  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([artifact_id, tag_id])
}

// ==========================================
// MODULE: DISCUSSION
// ==========================================

model Discussion {
  id          String  @id @default(ulid()) @db.Char(26)
  user_id     String  @db.Char(26)
  artifact_id String  @db.Char(26)
  parent_id   String? @db.Char(26)

  content String @db.Text

  // Denormalized Counters
  count_boosts  Int @default(0)
  count_reduces Int @default(0)
  count_replies Int @default(0)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  artifact      Artifact               @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  user          User                   @relation(fields: [user_id], references: [id])
  parent        Discussion?            @relation("NestedDiscussions", fields: [parent_id], references: [id], onDelete: Cascade)
  replies       Discussion[]           @relation("NestedDiscussions")
  engagements   EngagementDiscussion[]
  notifications Notification[]

  @@index([artifact_id], map: "idx_discussion_artifact_id")
  @@index([user_id], map: "idx_discussion_user_id")
  @@index([parent_id], map: "idx_discussion_parent_id")
}

// ==========================================
// MODULE: COLLECTION & AMPLIFY
// ==========================================

model Collection {
  id          String   @id @default(ulid()) @db.Char(26)
  user_id     String   @db.Char(26)
  artifact_id String   @db.Char(26)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)

  @@unique([user_id, artifact_id])
  @@index([user_id], map: "idx_collection_user_id")
}

model Amplify {
  id          String   @id @default(ulid()) @db.Char(26)
  user_id     String   @db.Char(26)
  artifact_id String   @db.Char(26)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)

  @@unique([user_id, artifact_id])
  @@index([user_id], map: "idx_amplify_user_id")
}

// ==========================================
// MODULE: ENGAGEMENT (BOOST/REDUCE)
// ==========================================

model EngagementArtifact {
  id          String             @id @default(ulid()) @db.Char(26)
  user_id     String             @db.Char(26)
  artifact_id String             @db.Char(26)
  type        EngagementVoteType

  created_at DateTime @default(now()) @db.Timestamp(6)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)

  @@unique([user_id, artifact_id]) // User hanya bisa 1 vote per artifact
  @@index([artifact_id], map: "idx_eng_artifact_id")
}

model EngagementDiscussion {
  id            String             @id @default(ulid()) @db.Char(26)
  user_id       String             @db.Char(26)
  discussion_id String             @db.Char(26)
  type          EngagementVoteType

  created_at DateTime @default(now()) @db.Timestamp(6)

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussion_id], references: [id], onDelete: Cascade)

  @@unique([user_id, discussion_id]) // User hanya bisa 1 vote per discussion
  @@index([discussion_id], map: "idx_eng_discussion_id")
}

// ==========================================
// MODULE: NOTIFICATION
// ==========================================

model Notification {
  id       String           @id @default(ulid()) @db.Char(26)
  user_id  String           @db.Char(26) // Penerima
  actor_id String?          @db.Char(26) // Pemicu (opsional untuk notif sistem)
  type     NotificationType
  is_read  Boolean          @default(false)

  artifact_id   String? @db.Char(26)
  discussion_id String? @db.Char(26)

  artifact   Artifact?   @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  discussion Discussion? @relation(fields: [discussion_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(6)

  user  User  @relation("ReceivedNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  actor User? @relation("TriggeredNotifications", fields: [actor_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_notification_user_id")
  @@index([is_read], map: "idx_notification_is_read")
}

// ==========================================
// MODULE: MEDIA
// ==========================================

model Media {
  id          String  @id @default(ulid()) @db.Char(26)
  artifact_id String  @db.Char(26)
  url         String  @db.VarChar(255) // Cloudflare R2 URL
  size        Int     @default(0)
  caption     String? @db.Text
  order       Int     @default(0)

  created_at DateTime @default(now()) @db.Timestamp(6)

  artifact Artifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)

  @@index([artifact_id], map: "idx_media_artifact_id")
}

// ==========================================
// ENUMS
// ==========================================

enum AuthType {
  CREDENTIAL
  GOOGLE
}

enum CollabStatusType {
  PENDING
  ACCEPTED
}

enum EngagementVoteType {
  BOOST
  REDUCE
}

enum NotificationType {
  COLLAB_INVITE
  NEW_DISCUSSION
  DISCUSSION_REPLY
  USER_MENTION
  NEW_WATCHER
}

enum JobStatus {
  FREELANCE
  OPEN_TO_WORK
  EMPLOYED
  NONE
}
